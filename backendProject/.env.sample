PORT=8000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# In production this MUST be the exact frontend origin (e.g. https://your-app.vercel.app) — not "*", since cookies use credentials
CORS_ORIGIN=http://localhost:5173
ACCESS_TOKEN_SECRET=kpx
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=kpx
REFRESH_TOKEN_EXPIRY=10d

# AI & RAG Chatbot Configuration
GEMINI_API_KEY=
# Optional overrides — defaults are current as of 2026; set these only if Google
# rotates model names. Generation falls back through gemini-flash-latest ->
# gemini-3.6-flash -> gemini-2.5-flash automatically when GEMINI_MODEL is unset.
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Qdrant Vector DB Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=